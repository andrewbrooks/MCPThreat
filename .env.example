# --- Database ---
# Dev uses SQLite. For prod, switch the datasource provider in prisma/schema.prisma
# to "postgresql" and set a Postgres connection string here.
DATABASE_URL="file:./dev.db"

# --- NextAuth ---
# Generate a strong secret: `openssl rand -base64 32`
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# --- GitHub OAuth (optional) ---
# The GitHub provider is only enabled when both values are present.
# Create an OAuth app: https://github.com/settings/developers
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_ID=""
GITHUB_SECRET=""

# --- Email (optional) ---
# When SMTP_HOST is set, finding alerts/reminders are emailed via SMTP.
# If unset, emails are logged to the server console instead of being sent.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="MCPThreat <no-reply@mcpthreat.local>"

# --- GitHub auto threat modeling (optional) ---
# ANTHROPIC_API_KEY enables "Import from GitHub" (Claude-powered analysis). When
# unset, the feature is disabled with a clear message and manual modeling is
# unaffected. ANALYSIS_MODEL overrides the model (default claude-opus-4-8).
# GITHUB_TOKEN is an optional server-side fallback for repo fetches (higher rate
# limits / private repos); the per-request token from the UI takes precedence and
# is never persisted.
ANTHROPIC_API_KEY=""
ANALYSIS_MODEL=""
GITHUB_TOKEN=""

# --- Reminders cron ---
# Secret required to call POST/GET /api/cron/reminders. Point an external scheduler
# (Vercel Cron, GitHub Action, system cron) at that route with this bearer token to
# dispatch recurring owner reminders.
CRON_SECRET=""
