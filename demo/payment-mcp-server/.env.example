# Port the Streamable HTTP transport listens on.
PORT=8848

# Downstream systems the payment tools call. Defaults point at internal hosts.
PROCESSOR_URL=https://processor.internal.local
LEDGER_URL=https://ledger.internal.local
RECEIPT_STORE_URL=https://receipts.internal.local

# The server's OWN scoped processor credential. Never a client-forwarded token.
PROCESSOR_API_KEY=sk_demo_processor_key

# Comma-separated egress allowlist for any URL the server fetches.
ALLOWED_EGRESS_HOSTS=processor.internal.local,ledger.internal.local,receipts.internal.local
